#!/usr/bin/env bash
# Usage:
#   focus-or-launch --app-id <APP_ID_REGEX> --command <command ...>
#   focus-or-launch webapp [--title <TITLE_REGEX>] <CHROMIUM_PWA_APPID> [<extra chromium args...>]
#   focus-or-launch --list
#
# Examples:
#   focus-or-launch --app-id '^firefox$' --command firefox
#   focus-or-launch webapp --title '^ChatGPT' fmgjjmmmlfnkbppncabfkddbjimcfncm

set -euo pipefail

# --- Browser Detection ---
get_browser() {
    for b in chromium-browser chromium google-chrome-stable brave-browser microsoft-edge; do
        if command -v "$b" >/dev/null 2>&1; then
            echo "$b"
            return 0
        fi
    done
    echo "No Chromium-based browser found" >&2
    exit 1
}

# Use the detected browser or fallback to your environment variable.
BROWSER_BIN=$(get_browser)
CHROMIUM_CMD=${CHROMIUM_CMD:-"$BROWSER_BIN --profile-directory=Default"}
# CHROMIUM_CMD=${CHROMIUM_CMD:-'/usr/bin/chromium --ozone-platform=wayland --enable-features=UseOzonePlatform --profile-directory=Default'}

# Argument parsing
APP_RE=""
TITLE_RE=""
CMD=()

if [[ $# -eq 0 ]]; then
  echo "Usage:
  niri-focus-or-launch --app-id <APP_ID_REGEX> --command <cmd>
  niri-focus-or-launch webapp [--title <TITLE_REGEX>] <CHROMIUM_PWA_APPID> [<extra chromium args...>]
  niri-focus-or-launch --list" >&2
  exit 2
fi

case "$1" in
  --list)
    niri msg --json windows | jq -r '.[] | "\(.id)\t\(.app_id // "NULL")\t\(.title // "")"'
    exit 0
    ;;
  webapp)
    shift
    if [[ "${1:-}" == "--title" ]]; then
      shift; TITLE_RE="$1"; shift
    fi
    [[ $# -ge 1 ]] || { echo "Missing webapp APP_ID" >&2; exit 2; }
    appid="$1"; shift

    APP_RE="chromium|google-chrome|brave-browser|$appid|crx_$appid"
    CMD=($CHROMIUM_CMD --app-id="$appid" "$@")
    ;;
  --app-id)
    shift
    APP_RE="$1"; shift
    if [[ "${1:-}" != "--command" ]]; then
      echo "Expected --command after --app-id" >&2; exit 2
    fi
    shift
    CMD=("$@")
    ;;
  *)
    echo "Unknown option: $1" >&2; exit 2
    ;;
esac

find_win_id() {
  niri msg --json windows | jq -r \
    --arg app_re "$APP_RE" --arg title_re "${TITLE_RE:-}" '
      .[] | select(
        ( .app_id? and (.app_id | test($app_re; "i")) )
        and
        ( $title_re == "" or ( .title? and (.title | test($title_re; "i")) ) )
      ) | .id
    ' | head -n1
}

id="$(find_win_id || true)"

if [[ -n "${id:-}" ]]; then
  niri msg action focus-window --id "$id" >/dev/null 2>&1 || true
else
  nohup "${CMD[@]}" >/dev/null 2>&1 &
  for _ in $(seq 1 50); do
    sleep 0.1
    id="$(find_win_id || true)"
    if [[ -n "${id:-}" ]]; then
      niri msg action focus-window --id "$id" >/dev/null 2>&1 || true
      break
    fi
  done
fi
