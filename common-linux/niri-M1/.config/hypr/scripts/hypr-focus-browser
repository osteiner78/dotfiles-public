#!/usr/bin/env sh
# Focus an already-open browser window (any of these classes), else launch one.

# Common Wayland classes you might use
CLASSES="firefox zen zen-beta zen-alpha chromium Google-chrome google-chrome-stable brave-browser Brave-browser vivaldi-stable vivaldi microsoft-edge microsoft-edge-stable floorp"

# Try to focus an existing browser
for c in $CLASSES; do
  if hyprctl clients | grep -qE "class:[[:space:]]*$c$"; then
    hyprctl dispatch focuswindow "class:$c"
    exit 0
  fi
done

# If none found, launch something sensible:
# 1) $BROWSER (if set), then $browser (your dotfiles var), then a candidate that exists.
if [ -n "$BROWSER" ]; then exec "$BROWSER"; fi
if [ -n "$browser" ]; then exec "$browser"; fi

for cmd in firefox zen-browser zen chromium google-chrome-stable google-chrome brave-browser vivaldi-stable microsoft-edge-stable floorp; do
  if command -v "$cmd" >/dev/null 2>&1; then exec "$cmd"; fi
done

# Fallback: nothing installed, do nothing (or notify-send if you use it)
exit 0
