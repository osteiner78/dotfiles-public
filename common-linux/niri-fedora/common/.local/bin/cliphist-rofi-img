#!/usr/bin/env bash

tmp_dir="/tmp/cliphist_thumbs"
mkdir -p "$tmp_dir"

if [ "$#" -eq 0 ]; then
    cliphist list | while read -r line; do
        # Extract the ID and the actual content
        id=$(echo "$line" | cut -f1)
        # Remove the ID and leading whitespace for the display text
        display_text=$(echo "$line" | sed 's/^[0-9]*\t//')

        if echo "$line" | grep -q "\[\[ binary data "; then
            thumb="$tmp_dir/$id.png"
            if [ ! -f "$thumb" ]; then
                cliphist decode "$id" > "$thumb"
            fi
            # Use \x1f (unit separator) to tell Rofi about the icon and the hidden ID
            echo -en "$display_text\0icon\x1f$thumb\x1finfo\x1f$id\n"
        else
            echo -en "$display_text\0info\x1f$id\n"
        fi
    done
else
    # $ROFI_INFO contains the hidden ID we passed earlier
    cliphist decode "$ROFI_INFO" | wl-copy
fi
