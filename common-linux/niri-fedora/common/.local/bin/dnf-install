#!/bin/bash

# Configuration for the fzf window
fzf_args=(
    --multi
    --preview 'echo "alt-p: toggle description, alt-j/k: scroll, F11: maximize"; echo; dnf info {1}'
    --preview-window 'down:65%:wrap'
    --bind 'alt-p:toggle-preview'
    --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
    --bind 'alt-k:preview-up,alt-j:preview-down'
)

# List available packages (name only) from enabled repositories
# dnf repoquery is the standard way to get a clean list of package names
# pkg_name=$(dnf repoquery -C --available --exclude-installed --queryformat "%{name}\n" | fzf "${fzf_args[@]}")
pkg_name=$(dnf repoquery --available --queryformat "%{name}\n" | fzf "${fzf_args[@]}")

# If a package was selected, install it and update the locate database
if [[ -n "$pkg_name" ]]; then
    sudo dnf install -y $pkg_name
    # On Fedora, the locate database update command is the same
    sudo updatedb
fi
