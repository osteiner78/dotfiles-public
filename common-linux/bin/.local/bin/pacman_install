#!/bin/bash

fzf_args=(
  --multi
  --preview 'echo "alt-p: toggle description, alt-j/k: scroll, F11: maximize"; echo; pacman -Si {1}'
  --preview-window 'down:65%:wrap'
  --bind 'alt-p:toggle-preview'
  --bind 'alt-d:preview-half-page-down,alt-u:preview-half-page-up'
  --bind 'alt-k:preview-up,alt-j:preview-down'
)

# List available packages (name only, one per line)
pkg_name=$(pacman -Slq | fzf "${fzf_args[@]}")

if [[ -n "$pkg_name" ]]; then
  sudo pacman -S "$pkg_name"
  sudo updatedb
fi
