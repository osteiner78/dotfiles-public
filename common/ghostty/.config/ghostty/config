# Environment
# Optional: Automatically launch tmux if you want
# command = /usr/bin/tmux

confirm-close-surface = false
shell-integration = detect
shell-integration-features = sudo,title,no-cursor

# Window Aesthetics
window-padding-x = 5
window-padding-y = 5
window-decoration = server
background-opacity = 1.00
background-blur = true
window-colorspace = srgb
alpha-blending = native
window-theme = ghostty

# Single instance & Automatic Quit
gtk-single-instance = true
quit-after-last-window-closed = true

# MacOS
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = visible
macos-window-buttons = hidden

# Font Configuration
font-family = "JetBrainsMono NF"
font-style = "Regular"
font-style-bold = "Bold"
font-style-italic = "Italic"
font-style-bold-italic = "Bold Italic"
font-size = 14

# Cursor Style
cursor-style = underline
cursor-style-blink = false
adjust-cursor-thickness = 3

# Selection & Clipboard
copy-on-select = clipboard
clipboard-paste-protection = false

# Theme 
# Ghostty has 300+ built-in themes. You can try:
theme = "Gruvbox Material Dark"
# Or import your specific one if it's a file:
# config-file = themes/gruvbox_material.config

# Keyboard Bindings
# keybind = ctrl+v=paste_from_clipboard  # commented out to allow Claude Code image paste via Ctrl+V
keybind = super+v=paste_from_clipboard
